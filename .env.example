# Frontend build-time env. Copy to `.env` (Vite auto-loads it) before `npm run build`.

# Backend base URL. Leave blank when the FastAPI backend serves this build
# (same origin); set it only for a split frontend/backend deployment.
VITE_API_BASE_URL=

# Google Sign-In — the OAuth 2.0 Web client ID from Google Cloud Console.
# Must match the backend's GOOGLE_CLIENT_ID. When blank, the Google button is hidden.
VITE_GOOGLE_CLIENT_ID=
